{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "behaving-agents",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-04-25",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "rules": [
    { "type": "Text", "globs": ["**/*.prompt"], "fallthrough": true }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/api/*"]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "WorkspaceAgent",
        "class_name": "WorkspaceAgent"
      },
      {
        "name": "BehaviorAgent",
        "class_name": "BehaviorAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["WorkspaceAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["BehaviorAgent"]
    }
  ]
}
